{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tzaffi/curio/schemas/textify_request.schema.json",
  "title": "Curio Textify Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "textify_request_version",
    "request_id",
    "preferred_output_format",
    "artifacts",
    "llm_caller"
  ],
  "properties": {
    "textify_request_version": {
      "const": "curio-textify-request.v1"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "preferred_output_format": {
      "type": "string",
      "enum": [
        "auto",
        "markdown",
        "txt"
      ]
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "llm_caller": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "name",
        "path",
        "mime_type",
        "sha256",
        "source_language_hint",
        "context"
      ],
      "properties": {
        "artifact_id": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "mime_type": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "sha256": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "source_language_hint": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "context": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
