{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tzaffi/curio/schemas/evaluation_payload.schema.json",
  "title": "Curio Evaluation Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "payload_version",
    "evaluated_at",
    "artifact",
    "dossier_snapshot",
    "evaluation"
  ],
  "properties": {
    "payload_version": {
      "const": "curio-evaluation-payload.v1"
    },
    "evaluated_at": {
      "$ref": "#/$defs/rfc3339UtcTimestamp"
    },
    "artifact": {
      "$ref": "#/$defs/artifact"
    },
    "dossier_snapshot": {
      "$ref": "#/$defs/dossierSnapshot"
    },
    "evaluation": {
      "$ref": "#/$defs/evaluation"
    }
  },
  "$defs": {
    "rfc3339UtcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "sheetRenderedUtcTimestamp": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2} UTC$"
    },
    "sheetRenderedUtcOrEmpty": {
      "type": "string",
      "pattern": "^(|\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2} UTC)$"
    },
    "sha256Hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "nullableNonEmptyString": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "prefixedLabel": {
      "type": "string",
      "pattern": "^(e|t):.+$"
    },
    "downloadRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Date",
        "X Date",
        "iMsgX",
        "Source",
        "Column",
        "Type",
        "Object"
      ],
      "properties": {
        "Date": {
          "$ref": "#/$defs/sheetRenderedUtcTimestamp"
        },
        "X Date": {
          "$ref": "#/$defs/sheetRenderedUtcOrEmpty"
        },
        "iMsgX": {
          "type": "string",
          "minLength": 1
        },
        "Source": {
          "type": "string",
          "minLength": 1
        },
        "Column": {
          "type": "string",
          "enum": [
            "Text",
            "X1",
            "X2",
            "X3"
          ]
        },
        "Type": {
          "type": "string",
          "enum": [
            "Tweet",
            "XArticle",
            "Repo",
            "HTMLPage",
            "Document",
            "Image",
            "AnimatedGif",
            "Video",
            "Link"
          ]
        },
        "Object": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "localArtifact": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256",
            "size_bytes",
            "mime_type"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "$ref": "#/$defs/sha256Hex"
            },
            "size_bytes": {
              "type": "integer",
              "minimum": 0
            },
            "mime_type": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "download_row",
        "local_artifact"
      ],
      "properties": {
        "download_row": {
          "$ref": "#/$defs/downloadRow"
        },
        "local_artifact": {
          "$ref": "#/$defs/localArtifact"
        }
      }
    },
    "textEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "block_id",
        "name",
        "language",
        "translation_of",
        "text",
        "was_truncated",
        "original_char_count"
      ],
      "properties": {
        "block_id": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "translation_of": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "text": {
          "type": "string"
        },
        "was_truncated": {
          "type": "boolean"
        },
        "original_char_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "translation_of": {
                "type": "integer"
              }
            },
            "required": [
              "translation_of"
            ]
          },
          "then": {
            "properties": {
              "language": {
                "type": "string",
                "pattern": "^en($|-.*)"
              }
            }
          }
        }
      ]
    },
    "dossierSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "assembled_at",
        "title_hint",
        "source_language_hint",
        "evidence_text",
        "details"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "tweet_json",
            "x_article_json",
            "html_page",
            "repo_zip",
            "image",
            "video",
            "animated_gif",
            "document",
            "link"
          ]
        },
        "assembled_at": {
          "$ref": "#/$defs/rfc3339UtcTimestamp"
        },
        "title_hint": {
          "$ref": "#/$defs/nullableNonEmptyString"
        },
        "source_language_hint": {
          "$ref": "#/$defs/nullableNonEmptyString"
        },
        "evidence_text": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/textEvidence"
          }
        },
        "details": {
          "type": "object"
        }
      }
    },
    "importance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "rationale"
      ],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "labelAssignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "score",
        "rationale"
      ],
      "properties": {
        "label": {
          "$ref": "#/$defs/prefixedLabel"
        },
        "score": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "labelKind": {
      "type": "string",
      "enum": [
        "topic",
        "entity"
      ]
    },
    "labelProposal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "kind",
        "parent",
        "description",
        "score",
        "rationale"
      ],
      "properties": {
        "label": {
          "$ref": "#/$defs/prefixedLabel"
        },
        "kind": {
          "$ref": "#/$defs/labelKind"
        },
        "parent": {
          "oneOf": [
            {
              "$ref": "#/$defs/prefixedLabel"
            },
            {
              "type": "null"
            }
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "entity"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "label": {
                "type": "string",
                "pattern": "^e:.+$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "topic"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "label": {
                "type": "string",
                "pattern": "^t:.+$"
              }
            }
          }
        }
      ]
    },
    "warning": {
      "type": "string",
      "minLength": 1
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "creator",
        "source_language",
        "summary_en",
        "importance",
        "labels",
        "proposals",
        "warnings"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "creator": {
          "$ref": "#/$defs/nullableNonEmptyString"
        },
        "source_language": {
          "type": "string",
          "minLength": 1
        },
        "summary_en": {
          "type": "string",
          "minLength": 1
        },
        "importance": {
          "$ref": "#/$defs/importance"
        },
        "labels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/labelAssignment"
          }
        },
        "proposals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/labelProposal"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
