{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tzaffi/curio/schemas/textify_response.schema.json",
  "title": "Curio Textify Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "textify_response_version",
    "request_id",
    "source",
    "llm",
    "warnings"
  ],
  "properties": {
    "textify_response_version": {
      "const": "curio-textify-response.v1"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "$ref": "#/$defs/textifiedSource"
    },
    "llm": {
      "oneOf": [
        {
          "$ref": "#/$defs/llmSummary"
        },
        {
          "type": "null"
        }
      ]
    },
    "warnings": {
      "$ref": "#/$defs/warnings"
    }
  },
  "$defs": {
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "nullableNonEmptyString": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableNonNegativeNumber": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "rfc3339UtcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "meteredObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "quantity",
        "unit"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "quantity": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "llmUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "reasoning_tokens",
        "total_tokens",
        "metered_objects",
        "started_at",
        "completed_at",
        "wall_seconds",
        "thinking_seconds"
      ],
      "properties": {
        "input_tokens": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "cached_input_tokens": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "output_tokens": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "reasoning_tokens": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "total_tokens": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "metered_objects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/meteredObject"
          }
        },
        "started_at": {
          "$ref": "#/$defs/rfc3339UtcTimestamp"
        },
        "completed_at": {
          "$ref": "#/$defs/rfc3339UtcTimestamp"
        },
        "wall_seconds": {
          "type": "number",
          "minimum": 0
        },
        "thinking_seconds": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        }
      }
    },
    "llmSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model",
        "usage",
        "cost_estimate"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "openai_api",
            "codex_cli",
            "google_document_ai"
          ]
        },
        "model": {
          "$ref": "#/$defs/nullableNonEmptyString"
        },
        "usage": {
          "$ref": "#/$defs/llmUsage"
        },
        "cost_estimate": {
          "oneOf": [
            {
              "$ref": "#/$defs/costEstimate"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "costEstimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "basis",
        "amount",
        "input_price_per_million",
        "cached_input_price_per_million",
        "output_price_per_million"
      ],
      "properties": {
        "currency": {
          "const": "USD"
        },
        "basis": {
          "const": "api_equivalent"
        },
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "input_price_per_million": {
          "type": "number",
          "minimum": 0
        },
        "cached_input_price_per_million": {
          "type": "number",
          "minimum": 0
        },
        "output_price_per_million": {
          "type": "number",
          "minimum": 0
        },
        "metered_price_per_thousand": {
          "type": "number",
          "minimum": 0
        },
        "metered_name": {
          "type": "string",
          "minLength": 1
        },
        "metered_unit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "suggestedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suggested_path",
        "output_format",
        "text"
      ],
      "properties": {
        "suggested_path": {
          "type": "string",
          "minLength": 1
        },
        "output_format": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "textifiedSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "input_mime_type",
        "source_sha256",
        "textification_required",
        "status",
        "suggested_files",
        "detected_languages",
        "page_count",
        "warnings"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "input_mime_type": {
          "$ref": "#/$defs/nullableNonEmptyString"
        },
        "source_sha256": {
          "$ref": "#/$defs/nullableNonEmptyString"
        },
        "textification_required": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "converted",
            "skipped_text_media",
            "unsupported_media",
            "no_text_found"
          ]
        },
        "suggested_files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/suggestedFile"
          }
        },
        "detected_languages": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "page_count": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "warnings": {
          "$ref": "#/$defs/warnings"
        }
      }
    }
  }
}
