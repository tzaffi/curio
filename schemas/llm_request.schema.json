{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tzaffi/curio/schemas/llm_request.schema.json",
  "title": "Curio LLM Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "llm_request_version",
    "request_id",
    "workflow",
    "instructions",
    "input",
    "output",
    "required_capabilities",
    "metadata"
  ],
  "properties": {
    "llm_request_version": {
      "const": "curio-llm-request.v1"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow": {
      "type": "string",
      "minLength": 1
    },
    "instructions": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/message"
      }
    },
    "output": {
      "$ref": "#/$defs/outputRequest"
    },
    "required_capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capability"
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "capability": {
      "type": "string",
      "enum": [
        "text_generation",
        "json_schema_output",
        "token_usage",
        "cached_input_usage",
        "reasoning_token_usage",
        "thinking_time",
        "subprocess",
        "file_input",
        "image_input",
        "pdf_input",
        "document_text_extraction",
        "ocr",
        "layout_extraction",
        "markdown_output",
        "plain_text_output",
        "suggested_file_output",
        "multiple_file_output",
        "relative_path_output",
        "metered_page_usage"
      ]
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "content"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "system",
            "user",
            "assistant"
          ]
        },
        "content": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/textContentPart"
              },
              {
                "$ref": "#/$defs/localFileContentPart"
              }
            ]
          }
        }
      }
    },
    "textContentPart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "text"
      ],
      "properties": {
        "type": {
          "const": "text"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "localFileContentPart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "path",
        "mime_type",
        "sha256",
        "name"
      ],
      "properties": {
        "type": {
          "const": "local_file"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "mime_type": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "outputRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "schema",
        "strict"
      ],
      "properties": {
        "type": {
          "const": "json_schema"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "type": "object"
        },
        "strict": {
          "type": "boolean"
        }
      }
    }
  }
}
