{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tzaffi/curio/schemas/translation_response.schema.json",
  "title": "Curio Translation Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "translation_response_version",
    "request_id",
    "target_language",
    "blocks",
    "llm",
    "warnings"
  ],
  "properties": {
    "translation_response_version": {
      "const": "curio-translation-response.v1"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "target_language": {
      "const": "en"
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/translatedBlock"
      }
    },
    "llm": {
      "$ref": "#/$defs/llmSummary"
    },
    "warnings": {
      "$ref": "#/$defs/warnings"
    }
  },
  "$defs": {
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "nullableNonEmptyString": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "nullableNonNegativeNumber": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "rfc3339UtcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "meteredObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "quantity",
        "unit"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "quantity": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "llmUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "reasoning_tokens",
        "total_tokens",
        "metered_objects",
        "started_at",
        "completed_at",
        "wall_seconds",
        "thinking_seconds"
      ],
      "properties": {
        "input_tokens": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "cached_input_tokens": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "output_tokens": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "reasoning_tokens": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "total_tokens": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        },
        "metered_objects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/meteredObject"
          }
        },
        "started_at": {
          "$ref": "#/$defs/rfc3339UtcTimestamp"
        },
        "completed_at": {
          "$ref": "#/$defs/rfc3339UtcTimestamp"
        },
        "wall_seconds": {
          "type": "number",
          "minimum": 0
        },
        "thinking_seconds": {
          "$ref": "#/$defs/nullableNonNegativeNumber"
        }
      }
    },
    "llmSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model",
        "usage",
        "cost_estimate"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "openai_api",
            "codex_cli"
          ]
        },
        "model": {
          "$ref": "#/$defs/nullableNonEmptyString"
        },
        "usage": {
          "$ref": "#/$defs/llmUsage"
        },
        "cost_estimate": {
          "oneOf": [
            {
              "$ref": "#/$defs/costEstimate"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "costEstimate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "basis",
        "amount",
        "input_price_per_million",
        "cached_input_price_per_million",
        "output_price_per_million"
      ],
      "properties": {
        "currency": {
          "const": "USD"
        },
        "basis": {
          "const": "api_equivalent"
        },
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "input_price_per_million": {
          "type": "number",
          "minimum": 0
        },
        "cached_input_price_per_million": {
          "type": "number",
          "minimum": 0
        },
        "output_price_per_million": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "translatedBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "block_id",
        "name",
        "detected_language",
        "english_confidence_estimate",
        "translation_required",
        "translated_text",
        "warnings"
      ],
      "properties": {
        "block_id": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "detected_language": {
          "type": "string",
          "minLength": 1
        },
        "english_confidence_estimate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "translation_required": {
          "type": "boolean"
        },
        "translated_text": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "warnings": {
          "$ref": "#/$defs/warnings"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "translation_required": {
                "const": true
              }
            },
            "required": [
              "translation_required"
            ]
          },
          "then": {
            "properties": {
              "translated_text": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "translation_required": {
                "const": false
              }
            },
            "required": [
              "translation_required"
            ]
          },
          "then": {
            "properties": {
              "translated_text": {
                "type": "null"
              }
            }
          }
        }
      ]
    }
  }
}
